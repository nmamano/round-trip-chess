{
  "name": "round-trip-chess",
  "module": "shared/engine.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run server/index.ts",
    "dev": "bun run --hot server/index.ts",
    "test": "bun test tests/",
    "format": "bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "lint": "bun x eslint .",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "ci": "bun x prettier --check . && bun x eslint . && bun run typecheck && bun test tests/"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "latest",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "nanoid": "^5.1.11"
  }
}
